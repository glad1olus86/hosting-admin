generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model DashboardAccount {
  id           Int                 @id @default(autoincrement())
  username     String              @unique @db.VarChar(50)
  email        String              @unique @db.VarChar(255)
  passwordHash String              @map("password_hash") @db.VarChar(255)
  role          String              @default("user") @db.VarChar(10)
  suspended     Boolean             @default(false)
  domainPattern String?             @map("domain_pattern") @db.VarChar(255)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  systemUsers   AccountSystemUser[]

  @@map("dashboard_accounts")
}

model AccountSystemUser {
  id             Int              @id @default(autoincrement())
  accountId      Int              @map("account_id")
  hestiaUsername String           @map("hestia_username") @db.VarChar(50)
  createdAt      DateTime         @default(now()) @map("created_at")
  account        DashboardAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, hestiaUsername])
  @@map("account_system_users")
}

model DomainMeta {
  id             Int       @id @default(autoincrement())
  domain         String    @unique @db.VarChar(255)
  expirationDate DateTime? @map("expiration_date") @db.Date
  comment        String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("domain_meta")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  accountId Int      @map("account_id")
  username  String   @db.VarChar(50)
  action    String   @db.VarChar(100)
  target    String?  @db.VarChar(255)
  details   String?  @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([accountId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  accountId Int      @map("account_id")
  username  String   @db.VarChar(50)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  browser   String?  @db.VarChar(100)
  os        String?  @db.VarChar(100)
  device    String?  @db.VarChar(100)
  country   String?  @db.VarChar(100)
  city      String?  @db.VarChar(100)
  isp       String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([accountId])
  @@index([createdAt])
  @@map("login_logs")
}

model MetricSnapshot {
  id          Int      @id @default(autoincrement())
  cpu         Float
  ramPercent  Float    @map("ram_percent")
  ramUsed     Int      @map("ram_used")
  ramTotal    Int      @map("ram_total")
  diskPercent Float    @map("disk_percent")
  netIn       BigInt   @map("net_in")
  netOut      BigInt   @map("net_out")
  recordedAt  DateTime @map("recorded_at") @db.DateTime(0)

  @@index([recordedAt])
  @@map("metric_snapshots")
}
